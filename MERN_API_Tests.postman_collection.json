{
  "info": {
    "name": "MERN User Management API",
    "description": "Postman collection to test all User API endpoints for the MERN internship project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Verify the Express server is running."
      },
      "response": []
    },
    {
      "name": "GET All Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        },
        "description": "Fetch all users from the database. Returns an array of user objects sorted newest first."
      },
      "response": [
        {
          "name": "200 OK - Users fetched",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"count\": 2,\n  \"data\": [\n    {\n      \"_id\": \"657f1a2b3c4d5e6f7a8b9c0d\",\n      \"name\": \"Alice Johnson\",\n      \"email\": \"alice@example.com\",\n      \"createdAt\": \"2024-01-15T10:30:00.000Z\",\n      \"updatedAt\": \"2024-01-15T10:30:00.000Z\"\n    },\n    {\n      \"_id\": \"657f1a2b3c4d5e6f7a8b9c0e\",\n      \"name\": \"Bob Smith\",\n      \"email\": \"bob@example.com\",\n      \"createdAt\": \"2024-01-14T08:20:00.000Z\",\n      \"updatedAt\": \"2024-01-14T08:20:00.000Z\"\n    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "POST Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        },
        "description": "Create a new user. Send name and email in the request body as JSON."
      },
      "response": [
        {
          "name": "201 Created - User created",
          "status": "Created",
          "code": 201,
          "body": "{\n  \"success\": true,\n  \"message\": \"User created successfully\",\n  \"data\": {\n    \"_id\": \"657f1a2b3c4d5e6f7a8b9c0d\",\n    \"name\": \"Alice Johnson\",\n    \"email\": \"alice@example.com\",\n    \"createdAt\": \"2024-01-15T10:30:00.000Z\",\n    \"updatedAt\": \"2024-01-15T10:30:00.000Z\"\n  }\n}"
        },
        {
          "name": "400 Bad Request - Missing fields",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"success\": false,\n  \"message\": \"Name and email are required\"\n}"
        },
        {
          "name": "409 Conflict - Duplicate email",
          "status": "Conflict",
          "code": 409,
          "body": "{\n  \"success\": false,\n  \"message\": \"A user with this email already exists\"\n}"
        }
      ]
    },
    {
      "name": "DELETE User by ID",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/657f1a2b3c4d5e6f7a8b9c0d",
          "host": ["{{baseUrl}}"],
          "path": ["users", "657f1a2b3c4d5e6f7a8b9c0d"]
        },
        "description": "Delete a user by their MongoDB _id. Replace the ID in the URL with a real _id from your database."
      },
      "response": [
        {
          "name": "200 OK - User deleted",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"message\": \"User deleted successfully\",\n  \"data\": {\n    \"_id\": \"657f1a2b3c4d5e6f7a8b9c0d\",\n    \"name\": \"Alice Johnson\",\n    \"email\": \"alice@example.com\"\n  }\n}"
        },
        {
          "name": "404 Not Found - User not found",
          "status": "Not Found",
          "code": 404,
          "body": "{\n  \"success\": false,\n  \"message\": \"User not found\"\n}"
        },
        {
          "name": "400 Bad Request - Invalid ID format",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"success\": false,\n  \"message\": \"Invalid user ID format\"\n}"
        }
      ]
    },
    {
      "name": "POST Create User - Missing Email (Test Validation)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        },
        "description": "Test server-side validation when email is missing. Should return 400."
      },
      "response": []
    },
    {
      "name": "DELETE User - Invalid ID (Test Error Handling)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/not-a-real-id",
          "host": ["{{baseUrl}}"],
          "path": ["users", "not-a-real-id"]
        },
        "description": "Test error handling when an invalid MongoDB ObjectId is provided. Should return 400."
      },
      "response": []
    }
  ]
}